{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and state",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "username": { "type": "string", "description": "Custom @username" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "username", "createdAt"]
    },
    "Username": {
      "title": "Username Claim",
      "description": "Mapping of username to userId to ensure uniqueness",
      "type": "object",
      "properties": {
        "userId": { "type": "string" }
      },
      "required": ["userId"]
    },
    "Question": {
      "title": "Question",
      "description": "An anonymous question submitted to a user",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "reply": { "type": "string", "description": "The answer from the user" },
        "repliedAt": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean", "description": "Whether the reply is published" }
      },
      "required": ["text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile"
    },
    "/usernames/{username}": {
      "schema": "Username",
      "description": "Unique username registry"
    },
    "/users/{userId}/questions/{questionId}": {
      "schema": "Question",
      "description": "Questions received by the user"
    }
  }
}
