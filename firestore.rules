rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // stats
    match /stats/{docId} {
      allow read: if true;
    }

    // Usernames Registry (Uniqueness check)
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(username);
    }

    // Users
    match /users/{userId} {
      allow get: if true; // Public profiles
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'bio', 'photoURL', 'username', 'isPortalOpen', 'portalExpiresAt']);
      
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'username', 'createdAt']) &&
               data.email is string && data.email.size() <= 256 &&
               data.username is string && data.username.matches('^[a-z0-9_]{3,20}$');
      }

      // Questions (Subcollection)
      match /questions/{questionId} {
        // Recipient can see all. Asker can see theirs.
        allow get: if isOwner(userId) || (isSignedIn() && existing().askerId == request.auth.uid);
        allow list: if isOwner(userId) || (isSignedIn() && resource.data.askerId == request.auth.uid);
        
        allow delete: if isOwner(userId) || (isSignedIn() && existing().askerId == request.auth.uid);
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasAny(['reply', 'repliedAt', 'isPublic']);
      }
    }

    // CollectionGroup for Replies
    match /{path=**}/questions/{questionId} {
        allow list: if isSignedIn() && resource.data.askerId == request.auth.uid;
        allow get: if isSignedIn() && resource.data.askerId == request.auth.uid;
    }
  }
}
